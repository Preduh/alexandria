# Database credentials (Postgres container setup)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgrespassword
POSTGRES_DB=agora

# Connection string for Prisma
# Standard format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:postgrespassword@localhost:5432/agora?schema=public"

# App configuration
PORT=8000
JWT_SECRET=any-long-random-string
NODE_ENV=development
