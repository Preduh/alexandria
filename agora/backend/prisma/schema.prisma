generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Entidade inicial do módulo de estudos para o banco de dados existir
model Subject {
  id          String   @id @default(uuid())
  name        String
  color       String   // Cor em HEX pra representar nos gráficos de performance
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
